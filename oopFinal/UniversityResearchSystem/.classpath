<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER"/>
	<classpathentry excluding="academic/|research/|services/|exceptions/|enums/|interfaces/|data/" kind="src" path="src"/>
	<classpathentry kind="src" path="src/academic"/>
	<classpathentry kind="src" path="src/data"/>
	<classpathentry kind="src" path="src/enums"/>
	<classpathentry kind="src" path="src/exceptions"/>
	<classpathentry kind="src" path="src/interfaces"/>
	<classpathentry kind="src" path="src/research"/>
	<classpathentry kind="src" path="src/services"/>
	<classpathentry kind="output" path="bin"/>
</classpath>
